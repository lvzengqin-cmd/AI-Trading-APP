<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80000000">

    <!-- 点击区域 -->
    <View
        android:id="@+id/overlay_touch_area"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 顶部提示栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="#161B22"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tv_overlay_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="请点击币安界面元素"
            android:textColor="#00D4AA"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:text="点击屏幕任意位置记录坐标，然后点击【完成】"
            android:textColor="#8B949E"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_overlay_done"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_primary"
                android:text="完成此步骤"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_overlay_cancel"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_secondary"
                android:text="结束配置"
                android:textColor="#F85149"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- 中心准星 -->
    <View
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:background="@drawable/ic_crosshair" />

</FrameLayout>